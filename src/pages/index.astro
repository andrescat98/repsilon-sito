---
import Layout from '../layouts/Layout.astro';
import { releases, events } from '../data/data';

const base = import.meta.env.BASE_URL || '/';
---

<Layout title="Home">
    <!-- HERO -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
        <!-- Sfondo animato — sostituisci con il tuo file video/gif/canvas -->

        <div class="fixed inset-0 z-0" id="bg-animated">
            <img src={`${base}images/bg.jpg`} alt="" class="w-full h-full object-cover" />
        </div>

        <!-- Overlay scuro -->
        <div class="absolute inset-0 z-10 bg-black/50"></div>

        <!-- Contenuto hero -->
        <div class="relative z-20 text-center px-6" id="hero-content">
            <h1 class="text-[clamp(5rem,20vw,18rem)] leading-none text-white opacity-0 animate-fadein" style="animation-delay: 0.5s;">REPSILON</h1>
            <div class="w-24 h-px bg-[#e8ff00] mx-auto mt-8 opacity-0 animate-fadein" style="animation-delay: 0.8s;"></div>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 opacity-0 animate-fadein" style="animation-delay: 1.2s;">
            <span class="text-xs tracking-widest text-white/50 uppercase">Scorri</span>
            <div class="w-px h-12 bg-linear-to-b from-white/50 to-transparent animate-bounce-slow"></div>
        </div>
    </section>

<!-- PROSSIMI EVENTI -->
<section class="w-full bg-black/80 relative z-10" style="padding-left: 3%; padding-right: 3%; padding-top: 2rem; padding-bottom: 1rem;">
    <div class="flex items-end justify-between mb-16">
        <h2 class="text-6xl md:text-8xl text-white">LIVE</h2>
        <div class="w-32 h-px bg-[#e8ff00] mb-3"></div>
    </div>

    {(() => {
        const now = new Date();
        const future = events.filter(e => new Date(e.dateISO) >= now);
        const past = events.filter(e => new Date(e.dateISO) < now).slice(-5);

        return (
            <>
                <div class="flex flex-col gap-0">
                    {future.length === 0 && (
                        <p class="text-white/40 text-sm tracking-widest uppercase py-8">— Stay tuned per i prossimi concerti —</p>
                    )}
                    {future.map((event) => (
                        <a href={event.link} target="_blank" class="group flex items-center justify-between py-7 border-t border-white/10 hover:border-[#e8ff00]/50 transition-all duration-300 hover:px-4">
                            <div class="flex items-center gap-8">
                                <span class="text-[#e8ff00] text-sm font-mono tracking-widest w-28">{event.date}</span>
                                <span class="text-white text-xl md:text-2xl font-light group-hover:text-[#e8ff00] transition-colors">{event.venue}</span>
                            </div>
                            <div class="flex items-center gap-6">
                                <span class="text-white/50 text-sm tracking-wider uppercase">{event.city}</span>
                                <span class="text-[#e8ff00] text-xs tracking-widest uppercase">→ Info e biglietti</span>
                            </div>
                        </a>
                    ))}
                    <div class="border-t border-white/10"></div>
                </div>

                {past.length > 0 && (
                    <div class="mt-16">
                        <h3 class="text-white/30 text-xs tracking-[0.4em] uppercase mb-6">Archivio eventi</h3>
                        <div class="flex flex-col gap-0">
                            {past.map((event) => (
                                <a href={event.link} target="_blank" class="group flex items-center justify-between py-5 border-t border-white/5 hover:border-white/20 transition-all duration-300 hover:px-4">
                                    <div class="flex items-center gap-8">
                                        <span class="text-white/30 text-sm font-mono tracking-widest w-28">{event.date}</span>
                                        <span class="text-white/40 text-xl md:text-2xl font-light group-hover:text-white/60 transition-colors">{event.venue}</span>
                                    </div>
                                    <div class="flex items-center gap-6">
                                        <span class="text-white/30 text-sm tracking-wider uppercase">{event.city}</span>
                                    </div>
                                </a>
                            ))}
                            <div class="border-t border-white/5"></div>
                        </div>
                    </div>
                )}
            </>
        );
    })()}
</section>
<!-- ALBUMS -->

<!-- PROSSIME USCITE -->
<section class="w-full bg-black/80 relative z-10" style="padding: 3rem 3% 5rem;">
    <div class="flex items-end justify-between mb-16">
        <h2 class="text-6xl md:text-8xl text-white">USCITE</h2>
        <div class="w-32 h-px bg-[#e8ff00]" style="margin-bottom: 1.5rem;"></div>
    </div>
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-15" style="padding: 1% 15%;">
        {releases.map((release) => (
            <div
                class="group cursor-pointer relative"
                style="perspective: 1000px;"
                onclick={`window.location.href='${base}${release.page}'`}
            >
                <!-- Custodia -->
                <div class="relative aspect-square overflow-hidden">
                    <img
                        src={release.cover}
                        alt={release.title}
                        class="w-full h-full object-cover opacity-100 group-hover:opacity-70 transition-opacity duration-500"
                        onerror="this.style.display='none'"
                    />
                    <div class="absolute inset-0 bg-linear-to-l from-black/60 via-transparent to-transparent"></div>
                    <div class="absolute bottom-0 left-0 right-0 p-8 bg-linear-to-t from-black via-black/30 to-transparent">
                        <p class="text-[#e8ff00] text-xs tracking-[0.3em] uppercase mb-1">{release.type} — {release.date}</p>
                        <h3 class="text-white text-3xl md:text-4xl" style="font-family:'Bebas Neue',sans-serif;">{release.title}</h3>
                    </div>
                </div>

                <!-- Vinile che sporge a destra -->
                <div
                    class="absolute top-[5%] -right-[4%] w-[90%] h-[90%] rounded-full transition-all duration-500 ease-out opacity-30 group-hover:opacity-100 group-hover:translate-x-8"
                    style="z-index: -1; background: radial-gradient(circle at 50% 50%, #2a2a2a 18%, #1a1a1a 19%, #222 45%, #111 46%, #1a1a1a 70%, #111 71%, #0a0a0a 100%); box-shadow: inset 0 0 30px rgba(0,0,0,0.8), -2px 0 15px rgba(0,0,0,0.5);"
                >
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[25%] h-[25%] rounded-full overflow-hidden" style="box-shadow: 0 0 8px rgba(0,0,0,0.9);">
                        <img src={release.cover} alt="" class="w-full h-full object-cover" onerror="this.style.display='none'" />
                    </div>
                </div>
            </div>
        ))}
    </div>
</section>

</Layout>

<style>
    @keyframes fadein {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fadein {
        animation: fadein 0.8s ease forwards;
    }

    @keyframes bounce-slow {
        0%,
        100% {
            transform: scaleY(1);
        }
        50% {
            transform: scaleY(1.3);
        }
    }

    .animate-bounce-slow {
        animation: bounce-slow 2s ease-in-out infinite;
    }
</style>
