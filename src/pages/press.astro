---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Press Kit">
    <div class="fixed inset-0 z-0">
        <img src="/images/bg.jpg" alt="" class="w-full h-full object-cover" />
    </div>

    <!-- Header pagina -->
    <section class="relative z-10 flex items-end" style="padding-left: 3%; padding-right: 3%; padding-top: 12rem; padding-bottom: 3rem;">
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="relative z-10">
            <p class="text-[#e8ff00] text-sm tracking-[0.4em] uppercase">Materiale stampa</p>
            <h1 class="text-[clamp(4rem,14vw,12rem)] leading-none text-white">PRESS KIT</h1>
        </div>
    </section>

    <!-- Contenuto -->
    <div class="w-full bg-black/80 relative z-10 presskit">
        <!-- Biografia -->
        <section class="mb-40">
            <div class="flex items-end justify-between mb-8">
                <h2 class="text-2xl md:text-4xl text-white">BIO</h2>
                <div class="w-32 h-px bg-[#e8ff00] mb-3"></div>
            </div>
            <p class="text-white/80 leading-relaxed mb-4">
                Vincenzo Reina, in arte <strong class="text-white">Repsilon</strong>, nasce nel 1998 in Sicilia. Da bambino sviluppa la passione per la chitarra
                studiando con un maestro di banda: solfeggio, teoria musicale, chitarra jazz e folk. Suona da oltre dieci anni.
            </p>
            <p class="text-white/80 leading-relaxed mb-4">
                Ispirato dai testi di Dylan, dalle atmosfere dei Radiohead, dai Beatles e dall'intimismo acustico di Damien Rice, nel 2020 pubblica il suo primo
                album autoprodotto <em>"Useless"</em> — brani introspettivi e melodie delicate. Nel 2021 segue <em>"Never Shine In Black"</em>, lavoro che segna
                una maggiore maturità artistica.
            </p>
            <p class="text-white/80 leading-relaxed">
                Attualmente Repsilon è al lavoro su un nuovo disco interamente in italiano, orientato alla sperimentazione sonora.
            </p>
        </section>

        <!-- Esperienze artistiche -->
        <section class="mb-40" style="padding-top: 2rem;">
            <div class="flex items-end justify-between mb-8">
                <h2 class="text-2xl md:text-4xl text-white">LIVE</h2>
                <div class="w-32 h-px bg-[#e8ff00] mb-6"></div>
            </div>
            <p class="text-white/80 leading-relaxed">
                A settembre 2022 debutta live al <strong class="text-white">Balconcino di Torino</strong> e sul palco dei <strong class="text-white"
                    >Torino Beatles Days</strong
                > alla Suoneria di Settimo Torinese. Nel 2023 si esibisce al Circolo Arci <strong class="text-white">Il Magazzino sul Po</strong>, al <strong
                    class="text-white">Collegno Fòl Fest</strong
                >, al <strong class="text-white">Civico Uno</strong>, al <strong class="text-white">Japs Festival</strong> di Chieri, alla <strong
                    class="text-white">Festa della Musica</strong
                > di Torino presso Off Topic, al <strong class="text-white">Torino Hidden Sounds</strong> e al <strong class="text-white">Teatro Q77</strong>.
            </p>
        </section>

        <!-- Collaborazioni -->
        <section class="mb-40" style="padding-top: 2rem;">
            <div class="flex items-end justify-between mb-8">
                <h2 class="text-2xl md:text-4xl text-white">COLLAB</h2>
                <div class="w-32 h-px bg-[#e8ff00] mb-3"></div>
            </div>
            <p class="text-white/80 leading-relaxed mb-4">
                Nel 2023 recita come protagonista nel videoclip di <em>"The Singer in the Band"</em> di <strong class="text-white">Marco Bonino</strong>,
                chitarrista dei Nuovi Angeli, per la regia di Andrea Valente — girato presso il locale storico torinese Le Roi.
            </p>
            <p class="text-white/80 leading-relaxed mb-4">
                Collabora con <strong class="text-white">Zeroallaquinta</strong>, associazione culturale torinese, come autore e esecutore delle musiche degli
                spettacoli teatrali <em>"Tra il terzo e il quarto piano"</em> e <em>"La chimera"</em>.
            </p>
            <p class="text-white/80 leading-relaxed">
                Ha composto le colonne sonore di diversi cortometraggi, tra cui <em>"Caged Soul"</em> e <em>"Far From Home"</em> del videomaker Giuseppe Bonanno.
            </p>
        </section>

        <!-- Discografia + Colonne sonore -->
        <section class="mb-40" style="padding-top: 2rem;">
            <div class="flex items-end justify-between mb-8">
                <h2 class="text-2xl md:text-4xl text-white">DISCO</h2>
                <div class="w-32 h-px bg-[#e8ff00] mb-3"></div>
            </div>
            <div class="grid md:grid-cols-2 gap-16">
                <div>
                    <p class="text-[#e8ff00] text-s tracking-[0.4em] uppercase mb-6">Discografia</p>
                    <ul class="space-y-2">
                        {
                            [
                                { year: '2020', title: 'Useless', href: 'https://open.spotify.com/intl-it/album/0Tebv5WFPZP9Popddzyu1z' },
                                { year: '2021', title: 'Never Shine In Black', href: 'https://open.spotify.com/intl-it/album/50K9CKxtFjCn60OC32Jhbx' },
                                { year: '2026', title: 'Onde', href: 'https://open.spotify.com/intl-it/album/3ocNyROi9LVgQ8AwsB2KGw' }
                            ].map((r) => (
                                <li class="text-white/80">
                                    <span class="text-[#e8ff00] font-mono text-xs mr-4">{r.year}</span>
                                    <a href={r.href} target="_blank" class="hover:text-[#e8ff00] transition-colors">
                                        {r.title}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
                <div>
                    <p class="text-[#e8ff00] text-s tracking-[0.4em] uppercase mb-6">Colonne sonore per corti</p>
                    <ul class="space-y-2">
                        {
                            [
                                { year: '2019', title: 'Far From Home' },
                                { year: '2020', title: 'Caged Soul' },
                                { year: '2022', title: 'Saudade' },
                                { year: '2022', title: 'Sonni Tranquilli' },
                                { year: '2022', title: 'Red Light' }
                            ].map((c) => (
                                <li class="text-white/80">
                                    <span class="text-[#e8ff00] font-mono text-xs mr-4">{c.year}</span>
                                    {c.title}
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </section>

        <!-- Stampa -->
        <section class="mb-40" style="padding-top: 2rem;">
            <div class="flex items-end justify-between mb-8">
                <h2 class="text-2xl md:text-4xl text-white">STAMPA</h2>
                <div class="w-32 h-px bg-[#e8ff00] mb-3"></div>
            </div>
            <p class="text-white/80 leading-relaxed mb-4">
                Repsilon è incluso nel libro <strong class="text-white">"Cantautori e cantautrici del nuovo millennio. Il dizionario"</strong> di Michele Neri, edito
                da Iacobelli Editore (gennaio 2023).
            </p>
            <p class="text-white/80 leading-relaxed">
                Il suo lavoro con Zeroallaquinta è stato citato da <strong class="text-white">TorinoToday</strong> e <strong class="text-white"
                    >Torino Giovani</strong
                >.
            </p>
        </section>

        <!-- Contatti -->
        <section class="mb-40" style="padding-top: 2rem;">
            <div class="flex items-end justify-between mb-8">
                <h2 class="text-2xl md:text-4xl text-white">CONTATTI</h2>
                <div class="w-32 h-px bg-[#e8ff00] mb-3"></div>
            </div>
            <a href="mailto:repsilonofficial@gmail.com" class="text-white/60 hover:text-[#e8ff00] transition-colors text-xl">repsilonofficial@gmail.com</a>
        </section>

        <div class="print:hidden flex justify-end pt-10">
            <button
                onclick="window.print()"
                class="inline-flex items-center gap-2 bg-[#e8ff00] text-black text-xs font-bold tracking-widest uppercase px-6 py-3 hover:bg-white transition-colors cursor-pointer"
            >
                ↓ Stampa / Salva come PDF
            </button>
        </div>
    </div>
</Layout>

<style>
    @media print {
        header {
            display: none !important;
        }
        .fixed {
            position: absolute !important;
        }
        body {
            background: white !important;
            color: black !important;
        }
        .bg-black\/80,
        .bg-black\/90,
        .bg-black\/50 {
            background: white !important;
        }
        .text-white,
        .text-white\/80,
        .text-white\/60 {
            color: black !important;
        }
        .text-\[\#e8ff00\] {
            color: #333 !important;
        }
        .border-white\/10 {
            border-color: #ccc !important;
        }
        a {
            color: #333 !important;
        }
        img {
            display: none !important;
        }
    }
</style>
