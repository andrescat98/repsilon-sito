<!doctype html>
<html lang="it">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Repsilon — Listening Park</title>
        <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Courier New', monospace;
                background: #1a2e1a;
                color: #e8ff00;
                height: 100vh;
                overflow: hidden;
                display: flex;
                flex-direction: column;
            }

            #login-screen {
                position: fixed;
                inset: 0;
                z-index: 100;
                background: #0d1a0d;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-direction: column;
                gap: 1.5rem;
            }
            #login-screen h1 {
                font-size: 2rem;
                letter-spacing: 0.3em;
                color: #e8ff00;
            }
            #login-screen p {
                color: #6a8a6a;
                font-size: 0.8rem;
                letter-spacing: 0.2em;
            }
            #login-screen input {
                background: transparent;
                border: 1px solid #e8ff00;
                color: #e8ff00;
                padding: 0.6rem 1.2rem;
                font-family: inherit;
                font-size: 1rem;
                outline: none;
                text-align: center;
                width: 220px;
            }
            #login-screen input::placeholder {
                color: #3a5a3a;
            }
            #login-screen button {
                background: #e8ff00;
                color: #0d1a0d;
                border: none;
                padding: 0.6rem 2rem;
                font-family: inherit;
                font-size: 0.85rem;
                letter-spacing: 0.2em;
                cursor: pointer;
                text-transform: uppercase;
            }
            #login-screen button:hover {
                background: white;
            }

            #hud {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 50;
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0.6rem 1.2rem;
                background: rgba(13, 26, 13, 0.85);
                border-bottom: 1px solid #2a4a2a;
                font-size: 0.7rem;
                letter-spacing: 0.15em;
            }
            #hud-name {
                color: #e8ff00;
            }
            #hud-players {
                color: #6a8a6a;
            }
            #hud-track {
                color: #a0c040;
            }

            #park-wrap {
                flex: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                padding-top: 2.5rem;
            }

            #park {
                position: relative;
                width: 600px;
                height: 500px;
                background: #2d5a2d;
                border: 2px solid #3a7a3a;
                border-radius: 8px;
                overflow: hidden;
                cursor: none;
            }

            #park::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image:
                    radial-gradient(circle at 20% 30%, #356635 1px, transparent 1px), radial-gradient(circle at 60% 70%, #3a6e3a 1px, transparent 1px),
                    radial-gradient(circle at 80% 20%, #2e5e2e 1px, transparent 1px), radial-gradient(circle at 40% 80%, #356635 1px, transparent 1px);
                background-size:
                    40px 40px,
                    60px 60px,
                    30px 30px,
                    50px 50px;
                opacity: 0.4;
            }

            .path-h {
                position: absolute;
                top: 50%;
                left: 10%;
                right: 10%;
                height: 18px;
                background: #8b7355;
                border-radius: 4px;
                transform: translateY(-50%);
                opacity: 0.7;
            }
            .path-v {
                position: absolute;
                left: 50%;
                top: 10%;
                bottom: 10%;
                width: 18px;
                background: #8b7355;
                border-radius: 4px;
                transform: translateX(-50%);
                opacity: 0.7;
            }

            .fountain {
                position: absolute;
                left: 50%;
                top: 50%;
                transform: translate(-50%, -50%);
                width: 48px;
                height: 48px;
                z-index: 5;
            }
            .fountain-base {
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 36px;
                height: 12px;
                background: #7a9ab0;
                border-radius: 50%;
                border: 2px solid #5a7a90;
            }
            .fountain-pillar {
                position: absolute;
                bottom: 10px;
                left: 50%;
                transform: translateX(-50%);
                width: 6px;
                height: 16px;
                background: #7a9ab0;
                border-radius: 2px;
            }
            .fountain-top {
                position: absolute;
                bottom: 24px;
                left: 50%;
                transform: translateX(-50%);
                width: 18px;
                height: 6px;
                background: #7a9ab0;
                border-radius: 50%;
                border: 2px solid #5a7a90;
            }
            .fountain-water {
                position: absolute;
                bottom: 28px;
                left: 50%;
                transform: translateX(-50%);
                width: 4px;
                height: 10px;
                background: linear-gradient(to top, #6ab0e0, transparent);
                border-radius: 2px;
                animation: water 1.2s ease-in-out infinite alternate;
            }
            @keyframes water {
                from {
                    height: 8px;
                    opacity: 0.7;
                }
                to {
                    height: 14px;
                    opacity: 1;
                }
            }

            .tree {
                position: absolute;
                width: 36px;
                height: 44px;
                z-index: 4;
            }
            .tree-top {
                width: 36px;
                height: 34px;
                background: radial-gradient(ellipse at 50% 60%, #4a8a2a, #2a5a10);
                border-radius: 50% 50% 40% 40%;
                position: absolute;
                top: 0;
            }
            .tree-trunk {
                width: 8px;
                height: 14px;
                background: #6b4226;
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                border-radius: 2px;
            }

            .bench {
                position: absolute;
                width: 32px;
                height: 20px;
                z-index: 4;
            }
            .bench-seat {
                position: absolute;
                top: 4px;
                left: 0;
                right: 0;
                height: 7px;
                background: #8b6914;
                border-radius: 2px;
                border-top: 2px solid #a07820;
            }
            .bench-back {
                position: absolute;
                top: 0;
                left: 2px;
                right: 2px;
                height: 5px;
                background: #8b6914;
                border-radius: 1px;
            }
            .bench-leg {
                position: absolute;
                bottom: 0;
                width: 4px;
                height: 8px;
                background: #6b4226;
                border-radius: 1px;
            }
            .bench-leg.left {
                left: 4px;
            }
            .bench-leg.right {
                right: 4px;
            }

            .bush {
                position: absolute;
                background: radial-gradient(ellipse, #3a7a1a, #1a4a0a);
                border-radius: 50%;
                z-index: 3;
            }

            .player {
                position: absolute;
                width: 20px;
                height: 24px;
                z-index: 10;
                transition:
                    left 0.15s,
                    top 0.15s;
                pointer-events: none;
            }
            .player-body {
                width: 14px;
                height: 14px;
                background: #e8ff00;
                border-radius: 50% 50% 40% 40%;
                position: absolute;
                top: 0;
                left: 50%;
                transform: translateX(-50%);
                border: 2px solid #b0c800;
            }
            .player-body.other {
                background: #40c0ff;
                border-color: #20a0e0;
            }
            .player-legs {
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 10px;
                height: 10px;
                background: #b0c800;
                border-radius: 2px;
            }
            .player-legs.other {
                background: #20a0e0;
            }
            .player-name {
                position: absolute;
                top: -16px;
                left: 50%;
                transform: translateX(-50%);
                font-size: 9px;
                white-space: nowrap;
                color: #e8ff00;
                letter-spacing: 0.05em;
                text-shadow: 0 0 4px #0d1a0d;
            }
            .player-name.other {
                color: #40c0ff;
            }

            #cursor {
                position: fixed;
                pointer-events: none;
                z-index: 200;
                width: 8px;
                height: 8px;
                background: #e8ff00;
                border-radius: 50%;
                transform: translate(-50%, -50%);
            }

            #controls {
                position: fixed;
                bottom: 0.8rem;
                left: 50%;
                transform: translateX(-50%);
                font-size: 0.65rem;
                color: #3a5a3a;
                letter-spacing: 0.15em;
            }

            #error-msg {
                color: #ff4040;
                font-size: 0.75rem;
                letter-spacing: 0.1em;
                display: none;
            }
        </style>
    </head>
    <body>
        <div id="cursor"></div>

        <div id="login-screen">
            <h1>REPSILON</h1>
            <p>LISTENING PARK</p>
            <input id="name-input" type="text" placeholder="il tuo nome" maxlength="16" />
            <button id="enter-btn">ENTRA</button>
            <span id="error-msg"></span>
        </div>

        <div id="hud" style="display:none;">
            <span id="hud-name"></span>
            <span id="hud-track">♪ —</span>
            <span id="hud-players">1 nel parco</span>
        </div>

        <div id="park-wrap" style="display:none;">
            <div id="park">
                <div class="path-h"></div>
                <div class="path-v"></div>

                <div class="fountain">
                    <div class="fountain-water"></div>
                    <div class="fountain-top"></div>
                    <div class="fountain-pillar"></div>
                    <div class="fountain-base"></div>
                </div>

                <div class="tree" style="left:20px;top:18px;"><div class="tree-top"></div><div class="tree-trunk"></div></div>
                <div class="tree" style="right:20px;top:18px;"><div class="tree-top"></div><div class="tree-trunk"></div></div>
                <div class="tree" style="left:20px;bottom:18px;"><div class="tree-top"></div><div class="tree-trunk"></div></div>
                <div class="tree" style="right:20px;bottom:18px;"><div class="tree-top"></div><div class="tree-trunk"></div></div>
                <div class="tree" style="left:130px;top:30px;"><div class="tree-top"></div><div class="tree-trunk"></div></div>
                <div class="tree" style="right:130px;top:30px;"><div class="tree-top"></div><div class="tree-trunk"></div></div>
                <div class="tree" style="left:130px;bottom:30px;"><div class="tree-top"></div><div class="tree-trunk"></div></div>
                <div class="tree" style="right:130px;bottom:30px;"><div class="tree-top"></div><div class="tree-trunk"></div></div>

                <div class="bench" style="left:80px;top:210px;">
                    <div class="bench-back"></div><div class="bench-seat"></div>
                    <div class="bench-leg left"></div><div class="bench-leg right"></div>
                </div>
                <div class="bench" style="right:80px;top:210px;">
                    <div class="bench-back"></div><div class="bench-seat"></div>
                    <div class="bench-leg left"></div><div class="bench-leg right"></div>
                </div>
                <div class="bench" style="left:268px;top:80px;">
                    <div class="bench-back"></div><div class="bench-seat"></div>
                    <div class="bench-leg left"></div><div class="bench-leg right"></div>
                </div>
                <div class="bench" style="left:268px;bottom:80px;">
                    <div class="bench-back"></div><div class="bench-seat"></div>
                    <div class="bench-leg left"></div><div class="bench-leg right"></div>
                </div>

                <div class="bush" style="width:24px;height:18px;left:70px;top:60px;"></div>
                <div class="bush" style="width:18px;height:14px;left:90px;top:68px;"></div>
                <div class="bush" style="width:24px;height:18px;right:70px;top:60px;"></div>
                <div class="bush" style="width:20px;height:16px;right:88px;top:66px;"></div>
                <div class="bush" style="width:22px;height:16px;left:70px;bottom:60px;"></div>
                <div class="bush" style="width:18px;height:14px;left:88px;bottom:66px;"></div>
                <div class="bush" style="width:24px;height:18px;right:70px;bottom:60px;"></div>
                <div class="bush" style="width:20px;height:16px;right:88px;bottom:66px;"></div>
            </div>
        </div>

        <div id="controls">WASD o frecce per muoversi</div>

        <script type="module">
            import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

            const SUPABASE_URL = 'https://ufmbpyguxqbamhzdpbkz.supabase.co';
            const SUPABASE_KEY =
                'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVmbWJweWd1eHFiYW1oemRwYmt6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMyMjY4NDksImV4cCI6MjA4ODgwMjg0OX0.gJdnlb8WhulnXThMv4fm8_QHkx864g2o4XSsBGvHbxI';
            const sb = createClient(SUPABASE_URL, SUPABASE_KEY);

            let myId = null;
            let myName = '';
            let pos = { x: 280, y: 230 };
            let players = {};
            const PARK_W = 600,
                PARK_H = 500;
            const SPEED = 3;
            const keys = {};

            // Cursore
            const cursor = document.getElementById('cursor');
            document.addEventListener('mousemove', (e) => {
                cursor.style.left = e.clientX + 'px';
                cursor.style.top = e.clientY + 'px';
            });

            // Login
            document.getElementById('enter-btn').addEventListener('click', enter);
            document.getElementById('name-input').addEventListener('keydown', (e) => {
                if (e.key === 'Enter') enter();
            });

            async function enter() {
                const input = document.getElementById('name-input');
                const name = input.value.trim();
                if (!name) return;
                myName = name;

                const errEl = document.getElementById('error-msg');
                errEl.style.display = 'none';

                const { data, error } = await sb
                    .from('players')
                    .insert({ name: myName, x: Math.round(pos.x), y: Math.round(pos.y) })
                    .select()
                    .single();

                if (error) {
                    errEl.textContent = 'Errore: ' + error.message;
                    errEl.style.display = 'block';
                    return;
                }

                myId = data.id;

                document.getElementById('login-screen').style.display = 'none';
                document.getElementById('hud').style.display = 'flex';
                document.getElementById('park-wrap').style.display = 'flex';
                document.getElementById('hud-name').textContent = '◉ ' + myName;

                await loadPlayers();
                subscribeRealtime();
                startPing();
                gameLoop();

                window.addEventListener('beforeunload', cleanup);
            }

            async function loadPlayers() {
                const { data } = await sb.from('players').select('*');
                if (!data) return;
                data.forEach((p) => {
                    if (p.id !== myId) updateOtherPlayer(p);
                });
                updateHudCount();
            }

            function subscribeRealtime() {
                sb.channel('park')
                    .on('postgres_changes', { event: '*', schema: 'public', table: 'players' }, (payload) => {
                        const p = payload.new || payload.old;
                        if (!p || p.id === myId) return;
                        if (payload.eventType === 'DELETE') {
                            removeOtherPlayer(p.id);
                        } else {
                            updateOtherPlayer(p);
                        }
                        updateHudCount();
                    })
                    .subscribe();
            }

            function updateOtherPlayer(p) {
                players[p.id] = p;
                let el = document.getElementById('pl-' + p.id);
                if (!el) {
                    el = document.createElement('div');
                    el.className = 'player';
                    el.id = 'pl-' + p.id;
                    el.innerHTML = `<div class="player-name other">${p.name}</div><div class="player-body other"></div><div class="player-legs other"></div>`;
                    document.getElementById('park').appendChild(el);
                }
                el.style.left = p.x + 'px';
                el.style.top = p.y + 'px';
            }

            function removeOtherPlayer(id) {
                delete players[id];
                const el = document.getElementById('pl-' + id);
                if (el) el.remove();
            }

            function updateHudCount() {
                const n = Object.keys(players).length + 1;
                document.getElementById('hud-players').textContent = n + ' nel parco';
            }

            document.addEventListener('keydown', (e) => {
                keys[e.key] = true;
                e.preventDefault();
            });
            document.addEventListener('keyup', (e) => {
                keys[e.key] = false;
            });

            let myEl = null;
            function getMyEl() {
                if (!myEl) {
                    myEl = document.createElement('div');
                    myEl.className = 'player';
                    myEl.id = 'pl-me';
                    myEl.innerHTML = `<div class="player-name">${myName}</div><div class="player-body"></div><div class="player-legs"></div>`;
                    document.getElementById('park').appendChild(myEl);
                }
                return myEl;
            }

            let lastSent = 0;
            function gameLoop() {
                let moved = false;
                if (keys['ArrowUp'] || keys['w'] || keys['W']) {
                    pos.y -= SPEED;
                    moved = true;
                }
                if (keys['ArrowDown'] || keys['s'] || keys['S']) {
                    pos.y += SPEED;
                    moved = true;
                }
                if (keys['ArrowLeft'] || keys['a'] || keys['A']) {
                    pos.x -= SPEED;
                    moved = true;
                }
                if (keys['ArrowRight'] || keys['d'] || keys['D']) {
                    pos.x += SPEED;
                    moved = true;
                }

                pos.x = Math.max(4, Math.min(PARK_W - 24, pos.x));
                pos.y = Math.max(4, Math.min(PARK_H - 28, pos.y));

                const el = getMyEl();
                el.style.left = pos.x + 'px';
                el.style.top = pos.y + 'px';

                if (moved && Date.now() - lastSent > 80) {
                    sb.from('players')
                        .update({ x: Math.round(pos.x), y: Math.round(pos.y) })
                        .eq('id', myId);
                    lastSent = Date.now();
                }

                requestAnimationFrame(gameLoop);
            }

            function startPing() {
                setInterval(() => {
                    sb.from('players').update({ last_seen: new Date().toISOString() }).eq('id', myId);
                }, 30000);
            }

            async function cleanup() {
                await sb.from('players').delete().eq('id', myId);
            }
        </script>
    </body>
</html>
