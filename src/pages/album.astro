---
import Layout from '../layouts/Layout.astro';
import { releases } from '../data/data';
---

<Layout title="Album & Video">
    <div class="fixed inset-0 z-0" id="bg-animated">
        <img src="/images/bg.jpg" alt="" class="w-full h-full object-cover" />
    </div>

    <!-- Header pagina -->
    <section class="relative z-10 flex items-end" style="padding-left: 5%; padding-right: 5%; padding-top: 12rem; padding-bottom: 3rem;">
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="relative z-10">
            <p class="text-[#e8ff00] text-sm tracking-[0.4em] uppercase mb-4">Discografia</p>
            <h1 class="text-[clamp(4rem,14vw,12rem)] leading-none text-white">ALBUM</h1>
        </div>
    </section>

    <!-- Griglia album -->
    <section class="w-full bg-black/80 relative z-10" style="padding: 3rem 5% 5rem;">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
                releases.map((release) => (
                    <div class="group relative overflow-hidden bg-zinc-900 aspect-square">
                        <div class="absolute inset-0 bg-linear-to-br from-zinc-800 to-black flex items-center justify-center">
                            <img
                                src={release.cover}
                                alt={release.title}
                                class="w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700"
                                onerror="this.style.display='none'"
                            />
                        </div>
                        <div class="absolute inset-0 bg-linear-to-t from-black via-black/20 to-transparent" />
                        <div class="absolute bottom-0 left-0 right-0 p-8">
                            <p class="text-[#e8ff00] text-xs tracking-[0.3em] uppercase mb-2">
                                {release.type} — {release.date}
                            </p>
                            <h3 class="text-white text-3xl md:text-4xl mb-4" style="font-family:'Bebas Neue',sans-serif;">
                                {release.title}
                            </h3>
                            <a
                                href={release.spotify}
                                target="_blank"
                                class="inline-flex items-center gap-2 text-xs font-bold tracking-widest uppercase text-black bg-[#e8ff00] px-4 py-2 hover:bg-white transition-colors opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 duration-300"
                            >
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
                                </svg>
                                Ascolta
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>
</Layout>
