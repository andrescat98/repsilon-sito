---
import Layout from '../layouts/Layout.astro';
import { releases } from '../data/data';
---

<Layout title="Album & Video">
    <div class="fixed inset-0 z-0" id="bg-animated">
        <img src="/images/bg.jpg" alt="" class="w-full h-full object-cover" />
    </div>

    <!-- Header pagina -->
    <section class="relative z-10 flex items-end" style="padding-left: 5%; padding-right: 5%; padding-top: 12rem; padding-bottom: 3rem;">
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="relative z-10">
            <p class="text-[#e8ff00] text-sm tracking-[0.4em] uppercase mb-4">Discografia</p>
            <h1 class="text-[clamp(4rem,14vw,12rem)] leading-none text-white">ALBUM</h1>
        </div>
    </section>

    <!-- Lista album -->
    <section class="w-full bg-black/80 relative z-10 min-h-screen" style="padding: 3rem 5% 5rem;">
        <div class="flex flex-col">
            {releases.map((release) => (
                <a
                    href={release.page}
                    class="group flex items-center gap-8 py-6 border-t border-white/10 hover:border-[#e8ff00]/50 hover:px-4 transition-all duration-300"
                >
                    <!-- Cover piccola -->
                    <div class="w-16 h-16 md:w-20 md:h-20 shrink-0 overflow-hidden bg-zinc-900">
                        <img
                            src={release.cover}
                            alt={release.title}
                            class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-opacity duration-300"
                            onerror="this.style.display='none'"
                        />
                    </div>

                    <!-- Info -->
                    <div class="flex-1">
                        <p class="text-[#e8ff00] text-xs tracking-[0.3em] uppercase mb-1">{release.type} — {release.date}</p>
                        <h3 class="text-white text-2xl md:text-3xl group-hover:text-[#e8ff00] transition-colors duration-300" style="font-family:'Bebas Neue',sans-serif;">{release.title}</h3>
                    </div>

                    <!-- Freccia -->
                    <span class="text-[#e8ff00] text-xs tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-300">→ Scopri</span>
                </a>
            ))}
            <div class="border-t border-white/10"></div>
        </div>
    </section>
</Layout>