---
import '../styles/globals.css';
import Header from '../components/Header.astro';

interface Props {
    title: string;
    description?: string;
}

const { title, description = '— Repsilon —' } = Astro.props;
---

<!doctype html>
<html lang="it">
    <head>
        <meta charset="UTF-8" />
        <title>{title} — Repsilon</title>
        <meta name="description" content="Repsilon — cantautore torinese. Ascolta gli album Onde, Never Shine In Black e Useless. Date live e press kit." />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="google-site-verification" content="JOfARyAYyoRqyJFG2KYvzmW1OySUdJ1CSbr563TDO0o" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
        <meta property="og:title" content="Repsilon" />
        <meta
            property="og:description"
            content="Repsilon — cantautore torinese. Ascolta gli album Onde, Never Shine In Black e Useless. Date live e press kit."
        />
        <meta property="og:image" content="https://repsilon.pages.dev/images/og-image.jpg" />
        <meta property="og:url" content="https://repsilon.pages.dev" />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content="https://repsilon.pages.dev/images/og-image.jpg" />

        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "MusicGroup",
                "name": "Repsilon",
                "url": "https://repsilon.pages.dev",
                "image": "https://repsilon.pages.dev/images/icon-r.jpg",
                "genre": "Cantautorato",
                "description": "Repsilon è il progetto musicale di Vincenzo Reina, cantautore nato in Sicilia nel 1998 e attivo a Torino. Autore degli album Useless (2020), Never Shine In Black (2021) e Onde (2026).",
                "foundingLocation": {
                    "@type": "Place",
                    "name": "Sicilia, Italia"
                },
                "member": {
                    "@type": "Person",
                    "name": "Vincenzo Reina"
                },
                "album": [
                    {
                        "@type": "MusicAlbum",
                        "name": "Onde",
                        "datePublished": "2026",
                        "url": "https://open.spotify.com/intl-it/album/3ocNyROi9LVgQ8AwsB2KGw"
                    },
                    {
                        "@type": "MusicAlbum",
                        "name": "Never Shine In Black",
                        "datePublished": "2021",
                        "url": "https://open.spotify.com/intl-it/album/50K9CKxtFjCn60OC32Jhbx"
                    },
                    {
                        "@type": "MusicAlbum",
                        "name": "Useless",
                        "datePublished": "2020",
                        "url": "https://open.spotify.com/intl-it/album/0Tebv5WFPZP9Popddzyu1z"
                    }
                ],
                "sameAs": [
                    "https://www.instagram.com/repsilon_/",
                    "https://www.tiktok.com/@repsilon",
                    "https://open.spotify.com/intl-it/artist/4hvkPM02c7e4jbmnTbrszD"
                ]
            }
        </script>
    </head>
    <body class="bg-black text-white overflow-x-hidden">
        <Header />
        <main>
            <slot />
        </main>
    </body>
</html>

<style is:global>
    :root {
        --accent: #e8ff00;
        --accent-dim: rgba(232, 255, 0, 0.15);
        --dark: #0a0a0a;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background-color: #000;
    }

    h1,
    h2,
    h3,
    .font-display {
        font-family: 'Bebas Neue', sans-serif;
        letter-spacing: 0.04em;
    }

    ::selection {
        background: var(--accent);
        color: #000;
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
        width: 4px;
    }
    ::-webkit-scrollbar-track {
        background: #000;
    }
    ::-webkit-scrollbar-thumb {
        background: var(--accent);
    }

    .descrizione {
        padding: 2.5rem 1%;
    }

    .presskit {
        padding: 5rem 5%;
    }

    .covergif {
        margin-left: -5%;
        margin-right: -5%;
        padding: 10pt 5%;
    }

    @media (min-width: 768px) {
        .descrizione {
            padding: 2.5rem 20%;
        }

        .presskit {
            padding: 5rem 20%;
        }
        .covergif {
            margin-left: -10%;
            margin-right: -10%;
            padding: 20pt 5%;
        }
    }
</style>
